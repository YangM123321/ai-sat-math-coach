APP_NAME=AI SAT Math Coach
# development | test | staging | production
# Only `production` triggers strict startup validation below.
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=false
DATABASE_URL=sqlite:///./sat_coach.db
DIAGNOSTIC_PROVIDER=rule_based
HUMAN_REVIEW_THRESHOLD=0.60
MAX_IMAGE_BYTES=5242880
REQUIRE_API_KEY=false
API_KEY=

# --- Required only when ENVIRONMENT=production ---------------------------
# The app refuses to start in production if any of these are missing,
# empty, a wildcard, or an obviously insecure placeholder value.

# Random value, at least 32 characters. Signs JWT access tokens
# (Phase 1.5 PR 3, HS256).
SECRET_KEY=

# Comma-separated list of explicit origins, e.g.:
#   CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
# Must not be empty or contain "*" in production.
CORS_ALLOWED_ORIGINS=

# Comma-separated list of explicit hostnames, e.g.:
#   TRUSTED_HOSTS=api.example.com
# Must not be empty or contain "*" in production.
TRUSTED_HOSTS=

# In production, DATABASE_URL must point at a server database (not SQLite)
# and explicitly request an encrypted connection -- "?sslmode=require" (or
# verify-ca/verify-full), or an equivalent driver-supported TLS parameter
# such as "ssl=true". "sslmode=disable/allow/prefer" do not count.
# Example:
#   DATABASE_URL=postgresql+psycopg://user:pass@host:5432/db?sslmode=require

# If REQUIRE_API_KEY=true in production, API_KEY must be at least 16
# characters and not a known placeholder value.

# --- Authentication (Phase 1.5 PR 3) --------------------------------------
# All have safe defaults; only SECRET_KEY above needs a real value in
# production (already enforced above).
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ISSUER=ai-sat-math-coach
JWT_AUDIENCE=ai-sat-math-coach-api
